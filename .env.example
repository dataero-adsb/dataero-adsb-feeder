# ADS-B Feeder Environment Variables

# Your API key for the Dataero ADS-B service
# Replace with your actual API key
API_KEY=your_api_key_here

# Feed mode — how data reaches Dataero:
#   reduce : readsb forwards a REDUCED Beast stream (with UUID) to the aggregator
#            natively via its beast_reduce_plus_out connector (edge reduction,
#            FR24-style; preferred). readsb only; configured by
#            feeder/configure_readsb_reduce.sh. This process only heartbeats.
#   beast  : this process byte-pumps the decoder's full :30005 Beast stream
#            (read-only, no decoder edit; works with any decoder, but full-rate).
#   json   : POST aircraft.json over HTTPS every 2s (works everywhere).
FEED_MODE=reduce

# --- reduce mode only ---------------------------------------------------------
# Feeder receiver id (UUID). Generated at install; bound to your account by
# Dataero registration. Used as readsb's --uuid for provenance.
RECEIVER_UUID=
# Dataero aggregator endpoint readsb forwards the reduced Beast to.
# Over the WireGuard mesh this becomes the hub tunnel IP (e.g. 10.7.0.1).
HUB_HOST=adsb.dataero.eu
HUB_PORT=30005
# readsb position-throttle interval in seconds (readsb default 0.25).
REDUCE_INTERVAL=0.25

# Set to TRUE to enable debug logging to /var/log/dataero-adsb-feeder.log
DEBUG=FALSE

# Path to the readsb aircraft data file (used by json mode / detection)
READSB_DATA=/run/readsb/aircraft.json
