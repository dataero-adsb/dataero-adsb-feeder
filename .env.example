# ADS-B Feeder Environment Variables

# Your API key for the Dataero ADS-B service
# Replace with your actual API key
API_KEY=your_api_key_here

# Feed mode — how data reaches Dataero:
#   beast : readsb forwards a REDUCED Beast stream (with UUID) to the feeder's
#           assigned Dataero ingest hub over a WIREGUARD tunnel (configured at
#           install from the registration response). Preferred; readsb only.
#           This process then only heartbeats the registrar.
#   json  : POST aircraft.json over HTTPS every 2s (the no-WireGuard fallback;
#           works with any decoder).
FEED_MODE=beast

# --- beast mode --------------------------------------------------------------
# Dataero registrar base URL (HTTPS, behind HAProxy). The installer calls
# <REGISTRAR_URL>/receivers/register once; main.py heartbeats
# <REGISTRAR_URL>/receivers/heartbeat.
REGISTRAR_URL=https://adsb.dataero.eu
# Feeder receiver id (UUID). Generated at install; bound to your account by the
# registration call. Used as readsb's --uuid for in-band provenance, and as the
# receiver_id the registrar/heartbeat key on. (The on-wire beast_id is the first
# 16 hex chars of this UUID — derived automatically.)
RECEIVER_UUID=
# Self-reported station position (the hub also records the public IP). OPTIONAL
# for plain ADS-B, but MANDATORY (and must be accurate — surveyed) when MLAT is
# enabled: MLAT error propagates directly from antenna-position error.
FEEDER_NAME=
FEEDER_LAT=
FEEDER_LON=
FEEDER_ALT_M=
# readsb position-throttle interval in seconds (readsb default 0.25). Edge
# reduction stays ON for the live-map backbone; MLAT is a SEPARATE full-rate
# stream (mlat-client reads the local full Beast :30005), not this one.
REDUCE_INTERVAL=0.25

# MLAT opt-in (epic ADSB-17). true => the installer registers with mlat_enabled,
# installs mlat-client, and runs dataero-mlat.service. Honoured by the server only
# with a full FEEDER_LAT/LON/ALT_M. The installer sets this; main.py ignores it
# (MLAT runs in its own service, not the heartbeat loop).
MLAT_ENABLED=false

# The following are populated by the installer from the registration response;
# they describe the assigned ingest hub/tunnel and (when MLAT is enabled) the
# central mlat-server endpoint mlat-client dials. Do not edit by hand.
#   SHARD, TUNNEL_IP, BEAST_HOST, BEAST_PORT, MLAT_SERVER_HOST, MLAT_SERVER_PORT
SHARD=
TUNNEL_IP=
BEAST_HOST=
BEAST_PORT=
MLAT_SERVER_HOST=
MLAT_SERVER_PORT=

# Set to TRUE to enable debug logging to /var/log/dataero-adsb-feeder.log
DEBUG=FALSE

# Path to the readsb aircraft data file (used by json mode / detection)
READSB_DATA=/run/readsb/aircraft.json
